# Server Configuration
PORT=5001
NODE_ENVIRONMENT=development

# Supabase Database Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gmail OAuth2 Configuration (for deployment notification emails)
# Setup guide: https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_USER=your-email@gmail.com
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token

# Lead Notification Configuration (optional)
# Discord webhook for lead notifications
LEAD_NOTIFY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-url

# Email notification settings for leads (optional - alternative to Discord)
LEAD_NOTIFY_USE_RESEND=false
LEAD_NOTIFY_FROM=noreply@yourdomain.com
LEAD_NOTIFY_TO=team@yourdomain.com
LEAD_NOTIFY_LOGO_URL=https://yourdomain.com/logo.png

# Resend API (optional - for alternative email service)
RESEND_API_KEY=re_your_resend_api_key_here

# Calendly API (for recording bookings via widget embed)
# Get from: Calendly → Integrations & Apps → Personal Access Tokens
CALENDLY_API_TOKEN=your-calendly-personal-access-token-here

# Nylas (for Domani email blasts)
NYLAS_API_KEY=your-nylas-api-key
NYLAS_GRANT_ID=your-nylas-grant-id

# Domani Supabase (read-only access for dashboard)
DOMANI_SUPABASE_URL=https://your-domani-project.supabase.co
DOMANI_SUPABASE_SERVICE_KEY=your-domani-service-role-key

# Blast secret — required X-Blast-Secret header on all email blast endpoints
# Generate with: openssl rand -hex 32
BLAST_SECRET=your-secret-here

# Webhook processor — set to "false" on all but one instance when
# horizontally scaling the API (prevents multiple instances from racing
# on the same pending_webhook_events rows). Defaults to true.
WEBHOOK_PROCESSOR_ENABLED=true

# Cloudflare R2 storage (for CMS image uploads)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_DEFAULT_BUCKET=pvs-cms-default
R2_DEFAULT_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
